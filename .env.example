# 复制为 .env 后填写真实值（不要提交密钥）

# Web 服务
JM_HOST=0.0.0.0
JM_PORT=18080
#JM_SESSION_SECRET=change-me

# SQLite（系统记录，Web 面板/HTTP API 以此为准）
JM_DB_PATH=/data/jellyfin_manager.db


# 可选：给脚本/外部程序调用 jm_manager API 用（值等于 /settings 里设置的 JM_API_KEY）
# JM_API_KEY=

# 可选：Restic 备份密码（不写入数据库）
# JM_BACKUP_RESTIC_PASSWORD=
